# Server
PORT=3000

# 360dialog — BSP provider for this clinic number
# API key generated in the 360dialog Hub (hub.360dialog.com)
# The key is already bound to the clinic phone number — no phone_number_id needed.
D360_API_KEY=your_360dialog_api_key_here

# Webhook verify token — registered in the 360dialog Hub webhook config
WEBHOOK_VERIFY_TOKEN=your_verify_token_here

# Supabase — Project Settings > API
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Calendly Booking Links (Etapa 2+)
LINK_PARTICULAR_ONLINE=https://calendly.com/inatale/consulta-particular-online
LINK_PARTICULAR_PRESENCIAL=https://calendly.com/inatale/consulta-particular-presencial
LINK_ALICE_ONLINE=https://calendly.com/inatale/consulta-convenio-online
LINK_ALICE_PRESENCIAL=https://calendly.com/inatale/consulta-convenio-presencial
